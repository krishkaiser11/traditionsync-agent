# .env.template
# Copy this file to .env and replace the values with your local paths/keys

# Path to your Google Cloud Service Account or Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\your\application_default_credentials.json"

# Your GCP Project ID
GOOGLE_CLOUD_PROJECT="your-project-id-here"

# Google Cloud Region
GOOGLE_CLOUD_LOCATION="global"

# ADK SDK Routing Flags
GOOGLE_GENAI_USE_VERTEXAI=1
GEMINI_USE_VERTEXAI=1
